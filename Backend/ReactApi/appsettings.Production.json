{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "#{DATABASE_URL}"
  },
  "Jwt": {
    "Key": "#{JWT_KEY}",
    "Issuer": "#{JWT_ISSUER}",
    "Audience": "#{JWT_AUDIENCE}",
    "Subject": "#{JWT_SUBJECT}",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  }
}
