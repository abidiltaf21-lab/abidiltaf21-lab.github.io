{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Data Source=reactapi.db"
  },

  "Jwt": {
    "_comment": "All values below MUST be supplied via environment variables in production (Jwt__Key, Jwt__Issuer, Jwt__Audience, Jwt__Subject). Do NOT commit real secrets here.",
    "Issuer": "SmooothPixel",
    "Audience": "SmooothPixelClients",
    "Subject": "SmooothPixelAuth",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },

  "Security": {
    "RequireHttps": true,
    "PasswordMinLength": 10,
    "RequireDigit": true,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireNonAlphanumeric": true,
    "RequiredUniqueChars": 4,
    "MaxFailedAccessAttempts": 5,
    "LockoutMinutes": 15,
    "OtpExpiryMinutes": 10,
    "OtpMaxAttempts": 3,
    "ExposeOtpInResponse": false,
    "EnableSwaggerInProduction": false
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://127.0.0.1:5173",
      "https://smooothpixel.com",
      "https://www.smooothpixel.com"
    ]
  },

  "Cloudinary": {
    "_comment": "Cloudinary credentials used by the backend for SIGNED uploads and the Media Library widget. Set Cloudinary__CloudName / Cloudinary__ApiKey / Cloudinary__ApiSecret via environment variables in production. NEVER put real values here in a public repo.",
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": "",
    "UploadPreset": "smooothpixel_upload",
    "Folder": "smooothpixel"
  }
}