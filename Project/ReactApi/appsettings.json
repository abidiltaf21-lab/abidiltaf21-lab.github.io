{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=ReactApi;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },

  "Jwt": {
    "Key": "A_Very_Complex_Secret_Key_That_Is_At_Least_32_Bytes_Long_123",
    "Issuer": "JwtIssuer",
    "Audience": "JwtAudience",
    "Subject": "JwtSubject",

    // 🔥 NEW IMPORTANT PROPERTIES
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },

  // 🔥 NEW: Security settings
  "Security": {
    "RequireHttps": true,
    "PasswordMinLength": 8,
    "RequireDigit": true,
    "RequireUppercase": true,
    "RequireNonAlphanumeric": true
  }
}