# Copy to .env and fill in your values. Do not commit .env.

# ASP.NET Core API (ReactApi)
# Dev (with Vite proxy): use /api  |  Production: full URL e.g. https://your-api.com/api
VITE_API_BASE_URL=/api

# Cloudinary (admin media uploads)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_API_KEY=your_api_key
VITE_CLOUDINARY_API_SECRET=your_api_secret

# Production API URL (for Vercel deployment)
# Replace with your Railway backend URL after deployment
VITE_PRODUCTION_API_URL=https://your-railway-app.railway.app/api
